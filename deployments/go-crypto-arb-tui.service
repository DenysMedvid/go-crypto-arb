[Unit]
Description=go-crypto-arb TUI
After=network-online.target go-crypto-arb-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/go-crypto-arb
EnvironmentFile=/opt/go-crypto-arb/.env
ExecStart=/usr/local/bin/go-crypto-arb-tui
Restart=on-failure
RestartSec=5s
User=go-crypto-arb
Group=go-crypto-arb
StandardInput=tty
StandardOutput=tty
TTYPath=/dev/tty1

[Install]
WantedBy=multi-user.target
